{
  "name": "wangdanatest-automation",
  "version": "1.0.0",
  "description": "Playwright-based automated testing for wangdanatest.top",
  "private": true,
  "keywords": [
    "playwright",
    "automation",
    "e2e",
    "testing",
    "qa"
  ],
  "author": "QA Team",
  "license": "MIT",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:e2e": "playwright test tests/e2e",
    "test:api": "playwright test tests/api",
    "test:security": "playwright test tests/security",
    "test:performance": "playwright test tests/performance",
    "test:accessibility": "playwright test tests/security/accessibility.spec.ts",
    "test:mobile": "playwright test --project='Mobile Chrome' --project='Mobile Safari'",
    "test:failed": "playwright test --last-failed",
    "test:report": "playwright show-report reports/html",
    "test:headed": "playwright test --headed",
    "test:watch": "playwright test --watch",
    "coverage": "nyc playwright test",
    "lint": "eslint . --ext .ts --max-warnings 70",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write 'tests/**/*.ts' 'scripts/**/*.sh'",
    "format:check": "prettier --check 'tests/**/*.ts' 'scripts/**/*.sh'",
    "install:browsers": "playwright install --with-deps",
    "pretest": "npm run lint:fix",
    "clean": "rm -rf reports coverage screenshots .test-cache",
    "clean:browsers": "playwright install --with-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.56.0",
    "axe-playwright": "^2.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "eslint-plugin-playwright": "^2.10.1",
    "nyc": "^18.0.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/wangdanatest-automation.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/wangdanatest-automation/issues"
  },
  "nyc": {
    "all": true,
    "include": [
      "tests/**/*.ts"
    ],
    "exclude": [
      "tests/**/*.spec.ts"
    ]
  }
}
