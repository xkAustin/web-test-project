# ============================================
# 测试配置环境变量 (Testing Configuration)
# ============================================

# 测试账户凭证 (Test Credentials) - 必需
TEST_USERNAME=your_test_username
TEST_PASSWORD=your_test_password

# 目标网站 URL (Target Website URL) - 可选（已在 playwright.config.ts 中配置）
# BASE_URL=https://www.wangdanatest.top

# 测试执行配置 (Test Execution)
# 无头浏览器模式（CI/CD 中推荐使用）
# HEADLESS=true

# 测试超时时间（毫秒）
# TIMEOUT=30000

# 日志级别（debug, info, warn, error）
# LOG_LEVEL=info

# 浏览器实例数（用于并行测试）
# WORKERS=4

# ============================================
# 高级配置 (Advanced Configuration)
# ============================================

# 代理设置（如需要）
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=https://proxy.example.com:8443

# 安全配置
# 是否验证 SSL 证书
# VERIFY_SSL=true

# 页面加载超时
# NAVIGATION_TIMEOUT=30000

# ============================================
# CI/CD 特定配置 (CI/CD Specific)
# ============================================

# GitHub Actions 工作流使用
# CI=true
# CI_COMMIT_SHA=abc123def456
# CI_COMMIT_REF=main
